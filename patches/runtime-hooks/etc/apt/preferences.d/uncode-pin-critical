# The custom-built dpkg shipped in our bootstrap is built with the
# custom prefix. Upstream dpkg binaries from the official repo do not
# have this, and replacing ours with theirs would brick the package
# manager (since paths like RUNPATH, sysconfdir, info-dir are baked
# for com.termux). We pin it with priority 1001 to forbid upgrades.
Package: dpkg
Pin: release *
Pin-Priority: 1001

# patchelf is load-bearing for the 98-uncode-patchelf Post-Invoke
# hook — without it, freshly-installed ELFs have wrong RUNPATH and
# fail at dlopen. Pin keeps it and prevents autoremove.
Package: patchelf
Pin: release *
Pin-Priority: 1001
